from Crypto.Cipher import AES
from Crypto.Util.number import long_to_bytes, bytes_to_long
from sage.all import *
import hashlib
# 1. Challenge Parameters (from your provided info)
p = 

# Only need enough pairs to solve the lattice; 20 is more than enough
pairs = [(, ), (, )] # Add more pairs from your output.txt here

# This is a sample enc_flag based on the challenge. Replace with YOUR value from output.txt
iv_hex = "00000000000000000000000000000000"
enc_flag_hex = "f9a76d8d6411a76d65492d56a7386d34..." 

# 2. Lattice Construction
# We use the relationship: y_i = sum(c_j * x_i^j) mod p
# Since c_j are small (256 bits) and p is large (1024 bits), LLL works.
num_coeffs = 30
num_pairs = len(pairs)

# Weights to balance the lattice (adjust if needed)
weight = p // (2**256)

L = Matrix(ZZ, num_pairs + num_coeffs, num_pairs + num_coeffs)
for i in range(num_pairs):
    x_i, y_i = pairs[i]
    for j in range(num_coeffs):
        L[j, i] = pow(x_i, num_coeffs - 1 - j, p)
    L[num_coeffs + i, i] = p

# Run LLL to find the short vector containing coefficients
print("Running LLL... this may take a moment.")
L_reduced = L.LLL()

# 3. Recover Key and Decrypt
for row in L_reduced:
    # Try the first element of each short vector as c_0 (MASTER_KEY)
    c0 = abs(row[0])
    if c0 > 0:
        potential_key = long_to_bytes(c0)
        # Verify if it's 32 bytes (SHA-256 size)
        if len(potential_key) <= 32:
            key = potential_key.rjust(32, b'\x00')
            cipher = AES.new(key, AES.MODE_CBC, bytes.fromhex(iv_hex))
            try:
                flag = cipher.decrypt(bytes.fromhex(enc_flag_hex))
                if b"picoCTF{" in flag:
                    print(f"Flag Found: {flag.decode()}")
                    break
            except:
                continue
